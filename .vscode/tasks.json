{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CI: Run canister test suite",
      "detail": "Install dependencies and run the full canister test suite",
      "type": "shell",
      "command": "bash scripts/install-dependencies.sh && bash scripts/run-canister-test-suite.sh",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "IC Dashboard: Run all snapshot queries",
      "detail": "Execute all SQL queries in queries.sql against ic_canisters.db",
      "type": "shell",
      "command": "sqlite3",
      "args": [
        "src/lib/ic_canister_snapshot/ic_canisters.db",
        "<",
        "src/lib/ic_canister_snapshot/queries.sql"
      ],
      "group": "test",
      "problemMatcher": []
    }
  ]
}